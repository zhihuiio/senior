{
  "name": "senior",
  "productName": "Senior",
  "version": "0.1.0",
  "private": false,
  "description": "Local-first AI requirement and task orchestrator desktop app.",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhihuiio/senior.git"
  },
  "homepage": "https://github.com/zhihuiio/senior#readme",
  "bugs": {
    "url": "https://github.com/zhihuiio/senior/issues"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "files": [
    "out/",
    "src/",
    "resources/",
    "docs/",
    "README.md",
    "LICENSE",
    "electron.vite.config.ts",
    "postcss.config.cjs",
    "tailwind.config.ts",
    "tsconfig.json",
    "components.json"
  ],
  "type": "module",
  "main": "out/main/index.js",
  "build": {
    "appId": "io.zhihui.senior",
    "productName": "Senior",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/build/Release/*.node"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "zhihuiio",
        "repo": "senior"
      }
    ]
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "pack:mac": "npm run build && electron-builder --mac --publish never",
    "pack:dmg": "npm run build && electron-builder --mac dmg --publish never",
    "release:mac": "npm run build && electron-builder --mac --publish always",
    "homebrew:cask": "node scripts/generate-homebrew-cask.mjs",
    "preview": "electron-vite preview",
    "test:freeform-agent": "node --test tests/main/agents/freeform-agent.test.cjs",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.92",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "pngjs": "^7.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@swc/core": "^1.15.24",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.27",
    "electron": "^41.1.1",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.2",
    "vite": "^7.3.2"
  }
}
